# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s

# PostgreSQL
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/notifier?sslmode=disable
POSTGRES_MAX_CONNS=25
POSTGRES_MIN_CONNS=5
POSTGRES_MAX_CONN_LIFETIME=1h

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Worker
WORKER_POOL_SIZE=10
WORKER_SCHEDULER_INTERVAL=5s
WORKER_BATCH_SIZE=100
WORKER_MAX_RETRIES=5
WORKER_RATE_LIMIT_PER_SEC=100

# Delivery (webhook.site URLs for development)
DELIVERY_WEBHOOK_BASE_URL=https://webhook.site
DELIVERY_EMAIL_PATH=/your-uuid-here
DELIVERY_SMS_PATH=/your-uuid-here
DELIVERY_PUSH_PATH=/your-uuid-here
DELIVERY_TIMEOUT=10s

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
TRACING_ENDPOINT=localhost:4317
